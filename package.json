{
  "name": "@unicitylabs/sphere-sdk",
  "version": "0.11.11",
  "description": "Modular TypeScript SDK for Unicity wallet operations",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./impl/browser": {
      "import": "./dist/impl/browser/index.js",
      "require": "./dist/impl/browser/index.cjs"
    },
    "./impl/browser/ipfs": {
      "import": "./dist/impl/browser/ipfs.js",
      "require": "./dist/impl/browser/ipfs.cjs"
    },
    "./impl/nodejs": {
      "import": {
        "types": "./dist/impl/nodejs/index.d.ts",
        "default": "./dist/impl/nodejs/index.js"
      },
      "require": {
        "types": "./dist/impl/nodejs/index.d.cts",
        "default": "./dist/impl/nodejs/index.cjs"
      }
    },
    "./impl/shared/wallet-api": {
      "import": {
        "types": "./dist/impl/shared/wallet-api/index.d.ts",
        "default": "./dist/impl/shared/wallet-api/index.js"
      },
      "require": {
        "types": "./dist/impl/shared/wallet-api/index.d.cts",
        "default": "./dist/impl/shared/wallet-api/index.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/core/index.d.ts",
        "default": "./dist/core/index.js"
      },
      "require": {
        "types": "./dist/core/index.d.cts",
        "default": "./dist/core/index.cjs"
      }
    },
    "./token-engine": {
      "import": {
        "types": "./dist/token-engine/index.d.ts",
        "default": "./dist/token-engine/index.js"
      },
      "require": {
        "types": "./dist/token-engine/index.d.cts",
        "default": "./dist/token-engine/index.cjs"
      }
    },
    "./wallet-api": {
      "import": {
        "types": "./dist/wallet-api/index.d.ts",
        "default": "./dist/wallet-api/index.js"
      },
      "require": {
        "types": "./dist/wallet-api/index.d.cts",
        "default": "./dist/wallet-api/index.cjs"
      }
    },
    "./connect": {
      "import": {
        "types": "./dist/connect/index.d.ts",
        "default": "./dist/connect/index.js"
      },
      "require": {
        "types": "./dist/connect/index.d.cts",
        "default": "./dist/connect/index.cjs"
      }
    },
    "./connect/browser": {
      "import": {
        "types": "./dist/impl/browser/connect/index.d.ts",
        "default": "./dist/impl/browser/connect/index.js"
      },
      "require": {
        "types": "./dist/impl/browser/connect/index.d.cts",
        "default": "./dist/impl/browser/connect/index.cjs"
      }
    },
    "./connect/nodejs": {
      "import": {
        "types": "./dist/impl/nodejs/connect/index.d.ts",
        "default": "./dist/impl/nodejs/connect/index.js"
      },
      "require": {
        "types": "./dist/impl/nodejs/connect/index.d.cts",
        "default": "./dist/impl/nodejs/connect/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "node scripts/gen-version.mjs",
    "build": "node scripts/build.mjs",
    "build:watch": "tsup --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "node -e \"const fs=require('fs');const must=['dist/index.d.ts','dist/core/index.d.ts','dist/token-engine/index.d.ts','dist/wallet-api/index.d.ts','dist/token-engine/index.js','dist/wallet-api/index.js'];const missing=must.filter(f=>!fs.existsSync(f));if(missing.length){console.error('prepublishOnly: dist is stale or incomplete — run npm run build first. Missing: '+missing.join(', '));process.exit(1)}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:relay": "vitest run --config vitest.relay.config.ts",
    "test:harness": "vitest run --config vitest.harness.config.ts",
    "test:e2e:live": "vitest run --config vitest.live.config.ts",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "cli": "echo 'The CLI has moved to @unicity-sphere/cli — install it with: npm install -g @unicity-sphere/cli' && exit 1"
  },
  "keywords": [
    "unicity",
    "wallet",
    "sdk",
    "crypto",
    "nostr",
    "ipfs"
  ],
  "author": "Unicity Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/unicity-sphere/sphere-sdk.git"
  },
  "dependencies": {
    "@noble/ciphers": "^2.2.0",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@unicitylabs/nostr-js-sdk": "^0.6.0",
    "@unicitylabs/state-transition-sdk": "2.0.0-rc.68bc1e5",
    "bip39": "^3.1.0",
    "buffer": "^6.0.3",
    "canonicalize": "^3.0.0",
    "crypto-js": "^4.2.0",
    "elliptic": "^6.6.1"
  },
  "optionalDependencies": {
    "@libp2p/crypto": "^5.1.13",
    "@libp2p/peer-id": "^6.0.4",
    "ipns": "^10.0.0",
    "multiformats": "^13.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@libp2p/bootstrap": "^12.0.11",
    "@libp2p/crypto": "^5.1.13",
    "@libp2p/interface": "^3.1.0",
    "@libp2p/peer-id": "^6.0.4",
    "@types/crypto-js": "^4.2.2",
    "@types/elliptic": "^6.4.18",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "fake-indexeddb": "^6.2.5",
    "multiformats": "^13.4.2",
    "testcontainers": "^11.11.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "~5.6.0",
    "typescript-eslint": "^8.54.0",
    "vitest": "^2.0.0",
    "ws": "^8.18.1"
  },
  "peerDependencies": {
    "@libp2p/crypto": ">=5.0.0",
    "@libp2p/peer-id": ">=6.0.0",
    "ipns": ">=10.0.0",
    "multiformats": ">=13.0.0",
    "ws": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    },
    "@libp2p/crypto": {
      "optional": true
    },
    "@libp2p/peer-id": {
      "optional": true
    },
    "ipns": {
      "optional": true
    },
    "multiformats": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
